{
  "version": 2,
  "buildCommand": "cp -r static internal/serverlite/static",
  "build": {
    "env": {
      "SIGNET_DEV_SEED": "1",
      "VERCEL": "1",
      "GO_VERSION": "1.25"
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/$1" }
  ],
  "headers": [
    {
      "source": "/embed/(.*)",
      "headers": [
        { "key": "Content-Security-Policy", "value": "frame-ancestors *" }
      ]
    }
  ]
}
